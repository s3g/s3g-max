{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Unix Makefiles dev build",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "/opt/homebrew/bin/gmake"
      }
    },
    {
      "name": "xcode",
      "displayName": "Xcode project",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-xcode"
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "xcode-release",
      "configurePreset": "xcode",
      "configuration": "Release"
    }
  ]
}

